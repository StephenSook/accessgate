# AccessGate — environment variable template
# Copy this file to .env and fill in real values.
# .env is git-ignored. Never commit real keys.

# --------------------------------------------------------------------------
# IBM watsonx.ai Lite (optional — enables the hosted showcase inference call)
# Get these from cloud.ibm.com after creating a watsonx.ai Lite project.
# --------------------------------------------------------------------------
WATSONX_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# --------------------------------------------------------------------------
# AccessGate API server (optional overrides)
# --------------------------------------------------------------------------
# Host and port for the FastAPI server (default: 0.0.0.0:8000)
# ACCESSGATE_HOST=0.0.0.0
# ACCESSGATE_PORT=8000

# --------------------------------------------------------------------------
# Ollama (optional overrides — defaults work if Ollama runs on localhost)
# --------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434

# --------------------------------------------------------------------------
# Logging level (DEBUG | INFO | WARNING | ERROR)
# --------------------------------------------------------------------------
# LOG_LEVEL=INFO
